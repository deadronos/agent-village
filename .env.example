# Server
HOST=127.0.0.1
PORT=4317

# Local SQLite database path. Keep this outside git-tracked source files.
AGENT_VILLAGE_DB_PATH=.data/agent-village.sqlite

# Set to 0 to disable the built-in mock adapter and only show posted real events.
AGENT_VILLAGE_MOCK_ADAPTER=1

# Web app
VITE_AGENT_VILLAGE_API_URL=http://127.0.0.1:4317
